# TrainHub environment variables
# Copy to `.env` for local dev, or pass via Docker secrets / your platform's
# secret manager for production. NEVER commit a real `.env` with real secrets.

# ── Required ────────────────────────────────────────────────────────────────
# JWT signing secret. MUST be set. The application refuses to start in
# production if this is missing. Use 32+ random bytes.
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Database connection. Defaults to a local SQLite file. Use the postgres://
# prefix to use the InsForge / Postgres adapter.
DATABASE_URL=file:./dev.db

# ── AI (Learning Studio) ──────────────────────────────────────────────────
# The Learning Studio routes (slides / quiz / RAG chat) need an LLM provider.
# Without these, those routes will return null and fall back to mock data.
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.chat
MINIMAX_CHAT_MODEL=MiniMax-Text-01
MINIMAX_EMBED_MODEL=embaab-01

# OpenAI fallback (used by lib/ai.ts). Leave blank to skip.
OPENAI_API_KEY=

# ── Optional — Turso (libSQL) ──────────────────────────────────────────────
# Use a hosted libSQL/Turso DB instead of the local SQLite file.
# TURSO_DATABASE_URL=
# TURSO_AUTH_TOKEN=

# ── Test only ──────────────────────────────────────────────────────────────
# Used by getSession() in test mode to forge a session. DO NOT set in prod.
# TEST_SESSION=

# ── Runtime ────────────────────────────────────────────────────────────────
NODE_ENV=development
